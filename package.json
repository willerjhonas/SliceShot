{
  "name": "sliceshot",
  "version": "1.0.0",
  "description": "Ferramenta para corte e conversão de imagens/PDFs para Figma",
  "main": "apps/electron/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node packages/core/slicer.js",
    "figma-slicer": "node packages/core/slicer.js",
    "renderer:dev": "cd apps/renderer && npm run dev",
    "renderer:build": "cd apps/renderer && npm run build",
    "electron:dev": "set NODE_ENV=development && electron .",
    "dev": "concurrently \"npm run renderer:dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "build": "npm run renderer:build && electron-builder"
  },
  "build": {
    "appId": "com.antigravity.corteprint",
    "productName": "Corte Print",
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "apps/electron/**",
      "packages/core/**",
      "apps/renderer/dist/**",
      "node_modules/**",
      "!node_modules/.cache"
    ]
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdf-to-png-converter": "^3.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^36.1.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  }
}